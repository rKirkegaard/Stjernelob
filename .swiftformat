# SwiftFormat-konfiguration for Stjerneløb.
# Afspejler .claude/rules/swift-style.md. Kører som hook (se .claude/settings.json)
# og håndhæves i CI (format-lint-jobbet).

--swiftversion 5.9
--indent 4
--maxwidth 100
--self remove
--importgrouping testable-bottom
--commas always
--trimwhitespace always
--ranges no-space
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first

# Bevar læsbare én-linjers bodies (jf. swift-style.md) — disse regler ville
# ellers sprænge fx `var id: String { rawValue }` ud over flere linjer.
--disable wrapPropertyBodies, wrapFunctionBodies, wrapLoopBodies

# Undgå at røre genererede/eksterne mapper.
--exclude .build,DerivedData,**/*.xcodeproj
